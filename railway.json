{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "cd backend && uvicorn app:app --host 0.0.0.0 --port $PORT"
  },
  "nixpacks": {
    "setup": {
      "installDeps": "cd backend && pip install -r requirements.txt"
    }
  }
}
