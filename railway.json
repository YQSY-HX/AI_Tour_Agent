{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "install": {
          "dependsOn": ["setup"],
          "cmds": ["pip install -r requirements.txt"],
          "cachedDirectories": ["/root/.cache/pip", "__pypackages__"]
        }
      },
      "providers": {
        "python": {
          "version": "3.11"
        }
      }
    },
    "root": "backend"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "uvicorn app:app --host 0.0.0.0 --port $PORT"
  }
}
