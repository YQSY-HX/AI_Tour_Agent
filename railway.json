{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "root": "backend",
    "nixpacksPlan": {
      "phases": {
        "install": {
          "dependsOn": ["setup"],
          "cmds": ["pip install -r requirements.txt"],
          "cachedDirectories": ["/root/.cache/pip"]
        }
      },
      "providers": [
        {
          "name": "python",
          "config": {
            "version": "3.11"
          }
        }
      ]
    }
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "uvicorn app:app --host 0.0.0.0 --port $PORT"
  }
}
