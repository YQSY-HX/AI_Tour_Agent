# Copy to .env and fill in your key
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
CHAT_MODEL=deepseek-chat

# Embeddings: DeepSeek has NO embedding API (404). Use local by default.
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# Optional: use existing m3e model from AI-Agent-Dev
# LOCAL_EMBEDDING_MODEL=E:/ai_study/AI-Agent-Dev/local_models/m3e-base

# Only if you have OpenAI or other embedding service:
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-xxx
# EMBEDDING_MODEL=text-embedding-3-small
