# Copy to .env and fill in your keys
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
CHAT_MODEL=deepseek-chat
# 如需多模态图片识别，请切换为视觉模型：
# CHAT_MODEL=qwen-vl-max          # 阿里通义千问（推荐）
# DEEPSEEK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# CHAT_MODEL=gpt-4o-mini          # OpenAI
# DEEPSEEK_BASE_URL=https://api.openai.com/v1

# Embedding: 火山引擎 Doubao Embedding API（OpenAI 兼容接口）
EMBEDDING_PROVIDER=volcano
VOLCANO_API_KEY=your-volcano-api-key
VOLCANO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCANO_EMBEDDING_MODEL=doubao-embedding-text-240715

# 语音识别：火山引擎 ASR
# 在火山引擎控制台 -> 语音技术 -> 应用管理 中获取 AppID
VOLCANO_ASR_APP_ID=your-asr-app-id
VOLCANO_ASR_CLUSTER=volcengine_streaming_common

# 语音合成：edge（默认免费）| volcano
TTS_PROVIDER=edge
# 火山 TTS 音色（仅 TTS_PROVIDER=volcano 时生效）
TTS_VOLCANO_VOICE=zh_female_xiaoling_tob

# 可选：使用本地 Embedding（回退方案）
# EMBEDDING_PROVIDER=local
# LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# 可选：使用 OpenAI 兼容 Embedding
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-xxx
# EMBEDDING_MODEL=text-embedding-3-small
